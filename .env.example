# =============================================================
# AquaLife API - Environment Variables Template
# =============================================================
# Sao chép file này thành .env và điền giá trị thực vào.
# KHÔNG commit file .env lên Git (đã có trong .gitignore).
# File này (.env.example) an toàn để commit vì không chứa credentials thực.

# -------------------------
# Server Configuration
# -------------------------
LOCAL_DEV_APP_HOST=localhost
LOCAL_DEV_APP_PORT=1704
APP_HOST=http://localhost:1704

# -------------------------
# MongoDB Atlas Connection
# -------------------------
# Lấy connection string từ MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net
DATABASE_NAME=AquaLife

# -------------------------
# Application Info
# -------------------------
AUTHOR=your_name_here

# -------------------------
# Build Mode
# -------------------------
# Giá trị: 'dev' (local) hoặc 'production' (server)
BUILD_MODE=dev

# -------------------------
# JWT Configuration
# -------------------------
# JWT_KEY: secret key để ký/verify token - phải đủ dài và ngẫu nhiên
# Tạo key ngẫu nhiên: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_KEY=your_very_long_and_random_secret_key_at_least_32_characters
JWT_EXPIRES_IN=1h

# Refresh Token
REFRESH_TOKEN_KEY=your_very_long_and_random_refresh_secret_key
REFRESH_TOKEN_EXPIRES_IN=14d
